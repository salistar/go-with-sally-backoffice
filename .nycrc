{
  "all": true,
  "include": [
    "gowithsally-backend/**/*.js"
  ],
  "exclude": [
    "gowithsally-backend/node_modules/**",
    "gowithsally-backend/dist/**",
    "tests/**",
    "**/*.test.js",
    "**/*.spec.js",
    "**/config/**",
    "**/seeds/**"
  ],
  "reporter": [
    "html",
    "text",
    "lcov",
    "text-summary"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "check-coverage": true,
  "lines": 80,
  "functions": 80,
  "branches": 75,
  "statements": 80
}
