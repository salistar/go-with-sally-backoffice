# ============================================================================
# GO WITH SALLY - ROOT ENVIRONMENT CONFIGURATION (TEMPLATE)
# ============================================================================
# Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env
# ============================================================================

# ── GENERAL ──────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=GoWithSally
APP_VERSION=2.0.0
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
LOG_LEVEL=debug

# ── MONGODB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=gowithsally_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_DB_NAME=gowithsally
MONGO_PORT=27017
MONGO_HOST=localhost
MONGODB_URI=mongodb://gowithsally_admin:CHANGE_ME@localhost:27017/gowithsally?authSource=admin
MONGODB_URI_DOCKER=mongodb://gowithsally_admin:CHANGE_ME@mongodb:27017/gowithsally?authSource=admin
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=CHANGE_ME

# ── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_ENABLED=false
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
REDIS_PREFIX=gws:
REDIS_TLS=false
REDIS_COMMANDER_PORT=8082
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=CHANGE_ME

# ── BACKEND API ──────────────────────────────────────────────────────────────
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
SIMULATION_MODE=true
TRUST_PROXY=false
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRE=90d
JWT_ISSUER=gowithsally
JWT_AUDIENCE=gowithsally-app
BCRYPT_ROUNDS=10
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── EMAIL (Nodemailer) ──────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Go With Sally <noreply@gowithsally.ma>

# ── SMS (Twilio) ────────────────────────────────────────────────────────────
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+212XXXXXXXXX

# ── PAYMENTS ─────────────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
CMI_ENABLED=false
CMI_STORE_ID=
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CASH_ENABLED=true
WALLET_ENABLED=true

# ── FIREBASE ────────────────────────────────────────────────────────────────
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── GOOGLE MAPS ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── FACE RECOGNITION ────────────────────────────────────────────────────────
FACE_API_PORT=8000
FACE_API_WORKERS=1
FACE_API_SECRET_KEY=CHANGE_ME_SECRET
FACE_API_PASSWORD=CHANGE_ME
FACE_VERIFICATION_ENABLED=true
FACE_RECOGNITION_THRESHOLD=0.75
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── MONITORING ──────────────────────────────────────────────────────────────
ENABLE_PROMETHEUS=true
SENTRY_DSN=

# ── SEED DATA ───────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@gowithsally.ma
SEED_ADMIN_PASSWORD=Admin@2024
SEED_SUBADMIN_PASSWORD=SubAdmin@2024
SEED_DRIVER_PASSWORD=Driver@2024
SEED_USER_PASSWORD=User@2024
