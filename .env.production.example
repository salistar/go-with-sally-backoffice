##############################################################################
# Go With Sally - Backoffice - .env.production (VPS, methode SallyCards)
#
# Sur le VPS :  cp .env.production.example .env.production ; nano .env.production
#               chmod 600 .env.production
# NE JAMAIS committer .env.production (gitignore).
##############################################################################

# ----- Images GHCR (poussees par deploy-prod.yml) -----
REGISTRY=ghcr.io
IMAGE_OWNER=salistar
IMAGE_TAG=latest

# ----- Reseau Docker partage ou vivent sallycards-mongo / sallycards-redis -----
SHARED_DB_NETWORK=shared-db

# ----- MongoDB : conteneur SallyCards REUTILISE, base dediee 'gowithsally' -----
# Reutiliser les credentials Mongo SallyCards existants (authSource=admin).
# Creer la base 'gowithsally' (isolee de 'sallycards'). Voir BACKOFFICE-DEPLOY.md.
MONGODB_URI=mongodb://sallycards:<MONGO_PWD_SALLYCARDS>@sallycards-mongo:27017/gowithsally?authSource=admin

# ----- Redis : conteneur SallyCards REUTILISE, index logiques dedies -----
REDIS_HOST=sallycards-redis
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PWD_SALLYCARDS>
REDIS_DB=3            # backend GoWithSally (sallycards utilise 0/1)
FACE_REDIS_DB=4       # face-api GoWithSally

# ----- Domaines (Cloudflare Tunnel) -----
APP_URL=https://api.gowithsally.salistar.com
FRONTEND_URL=https://gowithsally.salistar.com
FACE_API_URL=https://aigowithsally.salistar.com
CORS_ORIGINS=https://gowithsally.salistar.com,https://api.gowithsally.salistar.com,https://aigowithsally.salistar.com

# ----- Secrets applicatifs (GENERER : openssl rand -hex 64) -----
JWT_SECRET=<openssl rand -hex 64>
JWT_REFRESH_SECRET=<openssl rand -hex 64>
JWT_EXPIRE=30d
JWT_REFRESH_EXPIRE=90d
FACE_API_PASSWORD=<set-strong-password>
FACE_API_SECRET_KEY=<openssl rand -hex 32>
FACE_API_WORKERS=2

# ----- Integrations (laisser vide = desactive) -----
EMAIL_ENABLED=false
SMS_ENABLED=false
STRIPE_ENABLED=false
FIREBASE_ENABLED=false
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
SENTRY_DSN=

# ----- Le template d'origine complet est conserve ci-dessous -----
# (voir .env.production.example.bak pour toutes les variables optionnelles)
