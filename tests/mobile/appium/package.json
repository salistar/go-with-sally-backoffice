{
  "name": "gowithsally-mobile-tests",
  "version": "1.0.0",
  "description": "Mobile App Tests for GoWithSally using Appium",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:android": "wdio run wdio.conf.js --capabilities.platformName=Android",
    "test:ios": "wdio run wdio.conf.js --capabilities.platformName=iOS",
    "test:debug": "wdio run wdio.conf.js --logLevel=debug",
    "appium": "appium"
  },
  "devDependencies": {
    "@wdio/cli": "^8.11.0",
    "@wdio/local-runner": "^8.11.0",
    "@wdio/mocha-framework": "^8.11.0",
    "@wdio/spec-reporter": "^8.11.0",
    "@wdio/junit-reporter": "^8.11.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^2.9.0",
    "appium-xcuitest-driver": "^5.0.0",
    "chai": "^4.3.7",
    "wdio-appium-service": "^2.0.0"
  }
}
