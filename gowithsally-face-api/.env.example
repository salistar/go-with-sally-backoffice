# ==============================================================================
# GO WITH SALLY - Face AI Studio v4.0 - Environment Variables
# ==============================================================================
# Copy: cp .env.example .env
# Edit .env with your real values before launching
# ==============================================================================

# --- Server ---
PORT=8000
WORKERS=1                       # Dev: 1 | Prod: 2 (each worker loads ALL models)
LOG_LEVEL=info                  # debug, info, warning, error
APP_ENV=development             # development | staging | production
SECRET_KEY=change-me-in-prod-use-openssl-rand-hex-32

# --- Authentication ---
APP_PASSWORD=sally2024          # Password for web UI login
JWT_EXPIRY_HOURS=24             # API key expiry (0 = never)

# --- Pipeline Thresholds ---
CONF_HIGH=85.0                  # Above -> trust local model
CONF_LOW=60.0                   # Below -> escalate to next model
MATCH_STRICT=0.45               # Driver verification (strict)
MATCH_NORMAL=0.55               # Passenger verification (relaxed)

# --- AI API Keys (for future LLM-powered features) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
MISTRAL_API_KEY=

# --- External Face API Fallback (optional) ---
EXTERNAL_API_URL=               # e.g. https://api.deepface.io/v1

# --- Redis (for caching & rate limiting in prod) ---
REDIS_URL=redis://redis:6379/0

# --- Storage (S3-compatible for cloud deployments) ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=                    # Leave empty for AWS, set for MinIO/R2

# --- Monitoring ---
ENABLE_PROMETHEUS=true
SENTRY_DSN=                     # Optional: Sentry error tracking

# --- CORS ---
CORS_ORIGINS=*                  # Comma-separated origins or * for dev

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60        # Requests per minute per API key
