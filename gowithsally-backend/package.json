{
  "name": "gowithsally-backend",
  "version": "1.0.0",
  "description": "Go With Sally - Women-only ride-hailing backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeds/fullSeed.js",
    "seed:reset": "node seeds/fullSeed.js --reset",
    "seed:legacy": "node seeds/index.js",
    "seed:legacy:reset": "node seeds/index.js --reset",
    "db:clear": "node -e \"require('./config/database').connectMongoDB().then(() => require('mongoose').connection.dropDatabase().then(() => { console.log('Database cleared'); process.exit(0); }))\"",
    "test": "mocha tests/unit/**/*.test.js --timeout 10000",
    "test:unit": "mocha tests/unit/**/*.test.js --timeout 10000",
    "test:unit:watch": "mocha tests/unit/**/*.test.js --watch --timeout 10000",
    "test:coverage": "nyc mocha tests/unit/**/*.test.js --timeout 10000",
    "test:all": "npm run test:unit && npm run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "rideshare",
    "morocco",
    "women",
    "safety",
    "ride-hailing"
  ],
  "author": "Go With Sally Team",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs": "^4.17.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jimp": "^0.22.10",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^14.7.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "mocha": "^10.2.0",
    "chai": "^4.3.7",
    "sinon": "^17.0.1",
    "nyc": "^15.1.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
