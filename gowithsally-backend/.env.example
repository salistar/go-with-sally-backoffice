# ============================================================================
# GO WITH SALLY - BACKEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Database
MONGODB_URI=mongodb://localhost:27017/gowithsally

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=gowithsally-super-secret-key-change-in-production-2024
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=gowithsally-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRE=90d

# Email (Nodemailer - Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@gowithsally.com

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+212XXXXXXXXX

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Maps API
GOOGLE_MAPS_API_KEY=AIzaSyAhMNp4u70bsprZjUHwRvPME4JSn9O3xbk

# Face Recognition
FACE_RECOGNITION_THRESHOLD=0.75

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
