# GoWithSally Production Environment Configuration Template
# Copy this file to .env.production and populate with actual values
# DO NOT commit .env.production to version control
#
# Logging: This file serves as documentation for all required production variables
# Timestamp: Template created 2026-03-18

###############################################################################
# Server Configuration
###############################################################################

NODE_ENV=production
PORT=3000
HOST=0.0.0.0
API_URL=https://api.gowithsally.com
WEB_URL=https://app.gowithsally.com
MOBILE_URL=gowithsally://

###############################################################################
# Database Configuration
###############################################################################

# MongoDB
MONGODB_URI=mongodb://username:password@mongodb-host:27017/gowithsally?authSource=admin&retryWrites=true&w=majority
MONGODB_POOL_SIZE=10
MONGODB_SOCKET_TIMEOUT=30000

# MongoDB Backup
MONGODB_BACKUP_ENABLED=true
MONGODB_BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM
MONGODB_BACKUP_RETENTION_DAYS=30

###############################################################################
# Cache & Redis Configuration
###############################################################################

REDIS_URI=redis://username:password@redis-host:6379/0
REDIS_POOL_SIZE=20
REDIS_TTL=3600
REDIS_SESSION_TTL=86400

###############################################################################
# Authentication & Security
###############################################################################

# JWT Tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key
JWT_REFRESH_EXPIRES_IN=30d

# API Keys
API_KEY_SECRET=your-api-key-secret
API_KEY_HASH_ALGORITHM=sha256

# Session
SESSION_SECRET=your-session-secret-change-this
SESSION_TIMEOUT=3600000

# CORS
CORS_ORIGINS=https://app.gowithsally.com,https://web.gowithsally.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

###############################################################################
# File Upload & Storage
###############################################################################

# File Upload
MAX_FILE_SIZE=10485760 # 10MB
UPLOAD_DIR=/app/uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# S3/Cloud Storage (optional)
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

###############################################################################
# Email Configuration
###############################################################################

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@gowithsally.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Go With Sally
EMAIL_FROM_ADDRESS=noreply@gowithsally.com

# Email Templates
EMAIL_TEMPLATE_PATH=/app/templates/emails
EMAIL_VERIFICATION_TIMEOUT=24h
PASSWORD_RESET_TIMEOUT=1h

###############################################################################
# SMS & Communications
###############################################################################

# Twilio
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# Firebase Cloud Messaging
FCM_ENABLED=true
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY_ID=your-firebase-private-key-id
FCM_PRIVATE_KEY=your-firebase-private-key
FCM_CLIENT_EMAIL=your-firebase-client-email
FCM_CLIENT_ID=your-firebase-client-id
FCM_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FCM_TOKEN_URI=https://oauth2.googleapis.com/token

###############################################################################
# Payment Processing
###############################################################################

# Stripe
STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_API_VERSION=2023-10-16

# Payment Settings
PAYMENT_CURRENCY=MAD
PAYMENT_MIN_AMOUNT=10
PAYMENT_MAX_AMOUNT=5000
PAYMENT_TIMEOUT=300000

###############################################################################
# AI/ML Services
###############################################################################

# Face API
FACE_API_ENABLED=true
FACE_API_HOST=http://faceapi:5000
FACE_API_TIMEOUT=30000
FACE_API_GENDER_THRESHOLD=0.8
FACE_API_AGE_THRESHOLD=0.7
FACE_API_ANTISPOOF_THRESHOLD=0.85

# TensorFlow
TF_MODELS_PATH=/app/models
TF_MODEL_NAME=gender_age_detection_int8
TF_BATCH_SIZE=4
TF_DEVICE=cpu

###############################################################################
# Logging & Monitoring
###############################################################################

# Winston Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=/var/log/gowithsally
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=10
LOG_CONSOLE=false

# Sentry Error Tracking
SENTRY_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1
SENTRY_DEBUG=false

# Telegram Alerts
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_ALERT_LEVEL=error

###############################################################################
# Geolocation & Maps
###############################################################################

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_TIMEOUT=5000

# Geolocation
GEOLOCATION_PRECISION=6 # decimal places
GEOLOCATION_UPDATE_INTERVAL=5000 # milliseconds

###############################################################################
# Feature Flags & Toggles
###############################################################################

FEATURE_SURGE_PRICING=true
FEATURE_SCHEDULED_RIDES=true
FEATURE_SHARED_RIDES=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_DRIVER_BACKGROUND_CHECK=true
FEATURE_RIDE_INSURANCE=true
FEATURE_SOS_BUTTON=true

###############################################################################
# Database Maintenance
###############################################################################

# Cleanup & Maintenance
AUTO_CLEANUP_ENABLED=true
AUTO_CLEANUP_SCHEDULE=0 3 * * * # Daily at 3 AM
CLEANUP_RETENTION_DAYS=90
CLEANUP_BATCH_SIZE=1000

# Index Optimization
AUTO_INDEX_OPTIMIZATION=true
AUTO_INDEX_SCHEDULE=0 4 * * 0 # Weekly on Sunday at 4 AM

###############################################################################
# Docker & Deployment
###############################################################################

# Container Configuration
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=0.5

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

###############################################################################
# Development & Debugging
###############################################################################

# Only for production debugging - KEEP DISABLED
DEBUG=false
VERBOSE_LOGGING=false
STACK_TRACE_LIMIT=20

###############################################################################
# Additional Notes
###############################################################################

# 1. All secrets should be generated using strong random values
# 2. Never commit actual .env.production to version control
# 3. Use a secrets management system (Vault, AWS Secrets Manager, etc.)
# 4. Rotate JWT secrets and API keys regularly
# 5. Enable all security features in production
# 6. Monitor all services with appropriate logging levels
# 7. Set up alerts for critical errors via Telegram/Slack
# 8. Backup sensitive configuration separately from application code
# 9. Review and update this template quarterly
# 10. Document all custom environment variables added to this file
